{
  "name": "grow-logic",
  "version": "1.0.0",
  "private": true,
  "description": "GrowLogic Application",
  "keywords": [
    "Angular",
    "Signals",
    "PNPM",
    "ESLint",
    "Prettier",
    "HTMLHint",
    "Stylelint",
    "Husky",
    "lint-staged",
    "GitLeaks",
    "Secret Lint",
    "I18n",
    "Vite",
    "Vitest",
    "SonarCloud",
    "Snyk",
    "CodeQL",
    "GitHub Actions",
    "CICD",
    "Compodoc",
    "GitHub Pages",
    "Fontawesome",
    "Angular Material"
  ],
  "homepage": "https://www.growlogic.emmanuellefevre.com/home",
  "repository": {
    "type": "git",
    "url": "https://github.com/EmmanuelLefevre/growlogic"
  },
  "license": "MIT",
  "author": {
    "name": "Emmanuel Lefevre, Adrien Lazaille, Camille Hoareau, Rémy Nowe, Louise Delaunay, Nicolas Lombard",
    "url": "https://www.emmanuellefevre.com/"
  },
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22.21.1",
    "pnpm": ">=10.25.0"
  },
  "type": "module",
  "scripts": {
    "ng": "ng",
    "clean": "rimraf coverage .angular",
    "build": "pnpm clean && ng build",
    "doc": "node docs/_manage-doc.js serve",
    "doc:build": "node docs/_manage-doc.js build",
    "doc:ci": "node docs/_manage-doc.js build --keep",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "ng lint",
    "lint:html": "htmlhint \"src/**/*.html\"",
    "lint:scss": "stylelint \"src/**/*.scss\"",
    "lint:ci": "ng lint --max-warnings=0",
    "lint:html:ci": "htmlhint \"src/**/*.html\"",
    "lint:scss:ci": "stylelint \"src/**/*.scss\" --max-warnings=0",
    "lint:secrets": "secretlint \"**/*\"",
    "lint:security:ci": "eslint \"src/**/*.{ts,js}\" --config eslint-security.config.js",
    "prepare": "husky",
    "start": "ng serve",
    "test": "ng test",
    "test:coverage": "ng test --coverage --watch=false",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "watch": "ng build --watch --configuration development"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": ">=1.19.10",
      "@isaacs/brace-expansion": ">=5.0.1",
      "@modelcontextprotocol/sdk": ">=1.26.0",
      "express-rate-limit": ">=8.2.2",
      "flatted": ">=3.4.2",
      "hono": ">=4.12.4",
      "immutable": ">=5.1.5",
      "minimatch": ">=10.2.3",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "qs": ">=6.14.1",
      "rollup": ">=4.59.0",
      "tar": ">=7.5.11",
      "undici": ">=7.24.0"
    }
  },
  "dependencies": {
    "@angular/cdk": "21.2.2",
    "@angular/common": "21.2.4",
    "@angular/compiler": "21.2.4",
    "@angular/core": "21.2.4",
    "@angular/forms": "21.2.4",
    "@angular/material": "21.2.2",
    "@angular/platform-browser": "21.2.4",
    "@angular/router": "21.2.4",
    "@fortawesome/angular-fontawesome": "4.0.0",
    "@fortawesome/fontawesome-svg-core": "7.1.0",
    "@fortawesome/free-brands-svg-icons": "7.1.0",
    "@fortawesome/free-regular-svg-icons": "7.1.0",
    "@fortawesome/free-solid-svg-icons": "7.1.0",
    "@lottiefiles/dotlottie-web": "0.67.0",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "17.0.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "2.2.1",
    "@analogjs/vitest-angular": "2.3.1",
    "@angular-eslint/builder": "21.1.0",
    "@angular/build": "21.2.2",
    "@angular/cli": "21.2.2",
    "@angular/compiler-cli": "21.2.2",
    "@angular/platform-browser-dynamic": "21.2.4",
    "@compodoc/compodoc": "1.2.1",
    "@eslint/js": "9.39.1",
    "@secretlint/secretlint-rule-preset-recommend": "11.3.1",
    "@stylistic/eslint-plugin": "5.6.1",
    "@trivago/prettier-plugin-sort-imports": "6.0.0",
    "@types/node": "25.0.3",
    "@vitest/coverage-v8": "4.0.16",
    "@vitest/ui": "4.0.16",
    "angular-eslint": "21.1.0",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-security": "3.0.1",
    "htmlhint": "1.8.0",
    "husky": "9.1.7",
    "jsdom": "27.4.0",
    "lint-staged": "16.2.7",
    "postcss-scss": "4.0.9",
    "prettier": "3.7.4",
    "rimraf": "6.1.2",
    "secretlint": "11.3.1",
    "stylelint": "16.26.1",
    "stylelint-scss": "6.14.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.53.0",
    "vite": "7.3.0",
    "vite-tsconfig-paths": "6.0.3",
    "vitest": "4.0.16"
  },
  "lint-staged": {
    "*": [
      "secretlint --maskSecrets"
    ],
    "src/**/*.html": [
      "prettier --write",
      "eslint --fix --max-warnings=50",
      "htmlhint"
    ],
    "src/**/*.ts": [
      "eslint --fix --max-warnings=50"
    ],
    "**/*.{css,scss,json,md}": [
      "prettier --write"
    ],
    "*.scss": [
      "stylelint --fix"
    ],
    "*.{js,cjs,mjs}": [
      "eslint --fix --max-warnings=50",
      "prettier --write"
    ],
    "*.{yaml,yml}": [
      "prettier --write"
    ]
  }
}
