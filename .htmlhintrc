{
  "alt-require": true,
  "attr-lowercase": [
    "*ngTemplateOutlet",
    "#logoImage",
    "#renderContent",
    "(ngSubmit)",
    "[ariaLabel]",
    "[className]",
    "[formControl]",
    "[formGroup]",
    "[typeWriter]",
    "[isDisabled]",
    "[isLoading]",
    "[isRegisterMode]",
    "[matTooltip]",
    "[queryParams]",
    "[ngClass]",
    "[routerLink]",
    "matTooltipClass",
    "matTooltipPosition",
    "matTooltipShowDelay",
    "ngSrc",
    "routerLink",
    "routerLinkActive"
  ],
  "attr-no-duplication": true,
  "attr-no-unnecessary-whitespace": true,
  "attr-sorted": false,
  "attr-value-double-quotes": true,
  "attr-value-no-duplication": true,
  "attr-whitespace": false,
  "button-type-require": true,
  "doctype-first": false,
  "doctype-html5": false,
  "frame-title-require": true,
  "h1-require": false,
  "html-lang-require": true,
  "id-class-value": false,
  "id-unique": true,
  "inline-script-disabled": true,
  "inline-style": true,
  "input-requires-label": false,
  "main-require": false,
  "meta-charset-require": true,
  "meta-description-require": false,
  "meta-viewport-require": true,
  "spec-char-escape": true,
  "src-not-empty": true,
  "tag-no-obsolete": true,
  "tag-pair": true,
  "tag-self-close": true,
  "tagname-lowercase": true,
  "title-require": true
}
